# Webhook secret (from app registration in Teambridge)
TB_WEBHOOK_SECRET=your-webhook-secret

# OAuth2 credentials (from app registration in Teambridge)
TB_CLIENT_ID=your-client-id
TB_CLIENT_SECRET=your-client-secret

# Dev mode settings (for development outside of the teambridge iframe)
TB_DEV_MODE=true
TB_DEV_ACCOUNT_ID=your-account-id
TB_DEV_USER_ID=your-user-id
TB_DEV_USER_EMAIL=you@company.com
TB_DEV_USER_NAME="Your Name"

# Set V0_MODE=true when deploying on vercel to ensure v0 functions correctly (this will force dev mode when previewing in v0).
# V0_MODE=true


# App slug (when not in dev mode, used to build the asset prefix: https://api.teambridge.com/apps/<APP_SLUG>/)
APP_SLUG=your-app-slug

# API configuration (optional - defaults shown)
# TB_SERVER_BASE_URL=https://api.teambridge.com
# TB_OPEN_API_BASE_URL=https://open-api.teambridge.com
# TB_AUTH_URL=https://teambridge.us.auth0.com/oauth/token
# TB_AUDIENCE=https://api.teambridge.com/openapi/


