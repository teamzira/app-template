# Webhook secret (from app registration in Teambridge)
TB_WEBHOOK_SECRET=your-webhook-secret

# OAuth2 credentials (from app registration in Teambridge)
TB_CLIENT_ID=your-client-id
TB_CLIENT_SECRET=your-client-secret

# Dev mode settings (for local/v0 development)
# Automatically treated as true when VERCEL_ENV=development.
TB_DEV_MODE=true
TB_DEV_ACCOUNT_ID=your-account-id
TB_DEV_USER_ID=your-user-id
TB_DEV_USER_EMAIL=you@company.com
TB_DEV_USER_NAME=Your Name

# App slug (used to build the asset prefix: https://api.teambridge.com/apps/<APP_SLUG>/)
# Ignored when TB_DEV_MODE=true.
APP_SLUG=your-app-slug

# API configuration (optional - defaults shown)
# TB_API_BASE_URL=https://open-api.teambridge.com
# TB_AUTH_URL=https://teambridge.us.auth0.com/oauth/token
# TB_AUDIENCE=https://api.teambridge.com


